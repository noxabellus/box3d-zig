{
    "version": "2.0.0",
    "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
    },
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "zig build",
            "group": {
                "kind": "build",
                "isDefault": false,
            }
        },
        {
            "label": "run",
            "type": "shell",
            "command": "zig build run",
            "group": {
                "kind": "build",
                "isDefault": false,
            }
        },
        {
            "label": "test",
            "type": "shell",
            "command": "zig build test",
            "group": {
                "kind": "test",
                "isDefault": true,
            }
        },
    ],
}